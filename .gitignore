########################################
# Node.js dependencies and artifacts
########################################

# Installed packages (auto-generated, never commit)
node_modules/

# Dependency lockfile (ignore only if your workflow
# does NOT rely on reproducible installs)
package-lock.json


########################################
# macOS system files
########################################

# Finder metadata (created automatically in folders)
.DS_Store


########################################
# Local databases and history files
########################################

# SQLite databases or local caches
*.db


########################################
# Test and coverage output
########################################

# Coverage reports (e.g., Jest, nyc)
coverage/


########################################
# Editor and IDE configuration
########################################

# VS Code workspace settings (user-specific)
.vscode/
